<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Signed Out</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body
    class="min-h-screen bg-zinc-950 text-white flex items-center justify-center"
  >
    <div
      class="w-full max-w-md px-8 py-10 bg-zinc-900 rounded-2xl border border-zinc-800 text-center"
    >
      <h1 class="text-2xl font-semibold mb-2">Signed out</h1>
      <p class="text-zinc-400 text-sm mb-6">Your session has been ended.</p>
      <a href="/" class="text-sm text-zinc-300 hover:underline">Back to home</a>
      <p class="text-zinc-600 text-xs mt-8">
        Session ended by <span class="font-mono"><%= issuer %></span>
      </p>
    </div>
  </body>
</html>
